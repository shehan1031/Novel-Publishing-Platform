{
  "env":     { "node": true, "es2021": true },
  "extends": ["eslint:recommended"],
  "parserOptions": { "ecmaVersion": 2021 },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^(next|req|res|_)" }],
    "no-var":         "error",
    "prefer-const":   "warn",
    "no-console":     "off",
    "no-undef":       "error",
    "eqeqeq":         ["warn", "always"],
    "no-empty":       "warn",
    "no-unreachable": "warn"
  },
  "ignorePatterns": ["node_modules/", "uploads/"]
}