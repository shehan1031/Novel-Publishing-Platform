{
  "extends": ["react-app", "react-app/jest"],
  "rules": {
    "no-unused-vars":              "warn",
    "react-hooks/exhaustive-deps": "warn",
    "react/prop-types":            "off",
    "no-console":                  "off",
    "eqeqeq":                      "warn"
  },
  "ignorePatterns": ["build/", "node_modules/"]
}